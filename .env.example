# ==========================================================
# Copy this file to .env and fill in the keys you have.
# The system runs in FULL MOCK MODE with no keys at all -
# it will use local heuristics instead of live LLM calls,
# so you can clone, install, and run the demo immediately.
# ==========================================================

# --- LLM Provider for response generation & classification ---
# Leave blank to run in mock/offline mode (no external calls, no cost)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Which provider to prefer when a key is available: "anthropic" | "openai" | "mock"
LLM_PROVIDER=mock

# Model names (only used if the relevant key is set)
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings backend for RAG retrieval ---
# "tfidf" = local, free, offline, zero setup (default, recommended for this demo)
# "openai" = higher quality semantic search, requires OPENAI_API_KEY
EMBEDDING_BACKEND=tfidf

# --- App config ---
APP_ENV=development
LOG_LEVEL=INFO
ESCALATION_CONFIDENCE_THRESHOLD=0.55
